  sprite: {fileID: -3722995273477284230, guid: 256445a4f2327d5448b5b194b8147224, type: 3}
  title: "\u042E\u0434\u0436\u0438\u043D"
  description: "\u042E\u043D\u044B\u0439 \u0438 \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0439
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A. \u0427\u0430\u0441\u0442\u043E \u043F\u043E\u043F\u0430\u0434\u0430\u0435\u0442
    \u0432 \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043D\u043E \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0442\u0435\u0440\u044F\u0435\u0442
    \u0443\u043B\u044B\u0431\u043A\u0443 \u0438 \u0432\u0435\u0440\u0443 \u0432 \u0447\u0443\u0434\u0435\u0441\u0430.
    \u0421 \u0441\u0430\u043C\u043E\u0433\u043E \u0434\u0435\u0442\u0441\u0432\u0430
    \u0436\u0438\u0432\u0451\u0442 \u0432 \u0434\u043E\u043C\u0435 \u0432\u043C\u0435\u0441\u0441\u0442\u0435
    \u0441 \u0414\u0435\u0434\u0443\u0441\u043E\u043C, \u0438 \u043D\u0438\u043A\u0442\u043E
    \u0438\u0437 \u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u0434\u0435\u0440\u0435\u0432\u043D\u0438
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u043D\u0435 \u0437\u043D\u0430\u0435\u0442,
    \u0435\u0441\u0442\u044C \u043B\u0438 \u0443 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438."
  infoType: 2
