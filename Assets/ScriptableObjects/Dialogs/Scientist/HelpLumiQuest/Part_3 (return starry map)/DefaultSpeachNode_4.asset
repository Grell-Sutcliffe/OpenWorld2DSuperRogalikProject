  speach: "\u0414\u043B\u044F \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u043E \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u0430
    \u2014 \u043F\u043E\u0447\u0442\u0438 \u043A\u043E\u043C\u043F\u043B\u0438\u043C\u0435\u043D\u0442!
    \u0425\u043E\u0442\u044F... \u041A\u0442\u043E \u0437\u043D\u0430\u0435\u0442?
    \u041D\u043E \u044F \u0442\u043E\u0447\u043D\u043E \u0437\u043D\u0430\u044E \u043E\u0434\u043D\u043E
    \u2014 \u0431\u0435\u0437 \u0442\u0435\u0431\u044F \u044F \u0431\u044B \u043D\u0435
    \u0441\u043C\u043E\u0433 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043A\u0430\u0440\u0442\u0443, \u0438 \u0435\u0451 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u044B
    \u043D\u0430\u0432\u0435\u0447\u043D\u043E \u0431\u044B \u0437\u0430\u0442\u0435\u0440\u044F\u043B\u0438\u0441\u044C
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u043E\u0440\u0430\u0445 \u044D\u0442\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430, \u043F\u043E\u0433\u0430\u0441\u043D\u0443\u0432 \u0431\u0435\u0437
    \u0441\u043B\u0435\u0434\u0430."
